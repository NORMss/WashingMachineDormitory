# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:ABCDefGhIJKlmNoPQRsTUVwxYZ

# Telegram chat/group ID (negative for groups, e.g. -1001234567890)
CHAT_ID=-1001234567890

# URL of the laundry status server (the Russian server)
LAUNDRY_API_URL=https://your-laundry-server.ru

# PIN configured on the laundry server (STATUS_PIN env var there)
BOT_PIN=1234

# How often to poll the laundry API for status changes (seconds)
POLL_INTERVAL=30

# UTC offset for displaying times (3 = Moscow time UTC+3)
TIMEZONE_OFFSET=3
